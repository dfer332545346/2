<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>生日快乐!</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 99%, #fad0c4 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow-x: hidden;
        }

        .container {
            max-width: 800px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            padding: 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .container::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,154,158,0.1) 0%, rgba(253,208,196,0.1) 100%);
            animation: rotate 20s linear infinite;
            z-index: 0;
        }

        @keyframes rotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .content {
            position: relative;
            z-index: 1;
        }

        h1 {
            font-size: 3.5rem;
            color: #ff6b6b;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
            animation: bounce 2s ease-in-out infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-10px); }
            60% { transform: translateY(-5px); }
        }

        .birthday-cake {
            width: 200px;
            height: 150px;
            margin: 30px auto;
            position: relative;
        }

        .cake-base {
            width: 180px;
            height: 60px;
            background: #8b4513;
            border-radius: 10px 10px 0 0;
            position: absolute;
            bottom: 0;
            left: 10px;
        }

        .cake-top {
            width: 160px;
            height: 50px;
            background: #ff6b6b;
            border-radius: 10px 10px 0 0;
            position: absolute;
            bottom: 60px;
            left: 20px;
        }

        .candle {
            width: 10px;
            height: 40px;
            background: #ffd700;
            position: absolute;
            top: -40px;
            left: 95px;
            border-radius: 5px 5px 0 0;
        }

        .flame {
            width: 15px;
            height: 20px;
            background: #ff9800;
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            position: absolute;
            top: -20px;
            left: -2.5px;
            animation: flicker 1.5s ease-in-out infinite;
        }

        @keyframes flicker {
            0%, 100% { transform: scale(1); opacity: 0.9; }
            50% { transform: scale(1.1); opacity: 1; }
        }

        .message {
            font-size: 2rem;
            color: #ff6b6b;
            margin: 30px 0;
            line-height: 1.6;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        .star {
            position: fixed;
            width: 20px;
            height: 20px;
            background: #ffd700;
            clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            pointer-events: none;
            animation: starFloat 3s ease-in-out forwards;
        }

        @keyframes starFloat {
            0% {
                transform: scale(0) rotate(0deg);
                opacity: 1;
            }
            50% {
                transform: scale(1) rotate(180deg);
                opacity: 0.8;
            }
            100% {
                transform: scale(0) rotate(360deg);
                opacity: 0;
            }
        }

        .balloon {
            position: fixed;
            width: 80px;
            height: 100px;
            background: #ff6b6b;
            border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
            animation: balloonFloat 6s ease-in-out infinite;
        }

        .balloon::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            height: 30px;
            background: #333;
        }

        @keyframes balloonFloat {
            0%, 100% {
                transform: translateY(0) rotate(0deg);
            }
            50% {
                transform: translateY(-20px) rotate(5deg);
            }
        }

        @media (max-width: 768px) {
            .container {
                padding: 20px;
            }
            
            h1 {
                font-size: 2.5rem;
            }
            
            .birthday-cake {
                width: 150px;
                height: 110px;
            }
            
            .cake-base {
                width: 135px;
                height: 45px;
                left: 7.5px;
            }
            
            .cake-top {
                width: 120px;
                height: 37.5px;
                left: 15px;
                bottom: 45px;
            }
            
            .candle {
                left: 70px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="content">
            <h1>生日快乐!</h1>
            
            <div class="birthday-cake">
                <div class="cake-base"></div>
                <div class="cake-top"></div>
                <div class="candle">
                    <div class="flame"></div>
                </div>
            </div>
            
            <p class="message">
                祝你生日快乐！
            </p>
        </div>
    </div>

    <script>
        // 生成气球
        function createBalloons() {
            const colors = ['#ff6b6b', '#4ecdc4', '#45b7d1', '#96ceb4', '#ffeaa7'];
            
            for (let i = 0; i < 10; i++) {
                const balloon = document.createElement('div');
                balloon.className = 'balloon';
                balloon.style.left = Math.random() * 100 + 'vw';
                balloon.style.top = Math.random() * 100 + 'vh';
                balloon.style.background = colors[Math.floor(Math.random() * colors.length)];
                balloon.style.animationDelay = Math.random() * 6 + 's';
                document.body.appendChild(balloon);
            }
        }

        // 生成星星
        function createStars(event) {
            const starColors = ['#ffd700', '#ffed4e', '#ffff8c', '#fff9c4'];
            
            for (let i = 0; i < 20; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = (event.clientX + (Math.random() - 0.5) * 200) + 'px';
                star.style.top = (event.clientY + (Math.random() - 0.5) * 200) + 'px';
                star.style.background = starColors[Math.floor(Math.random() * starColors.length)];
                star.style.animationDelay = Math.random() * 1 + 's';
                star.style.animationDuration = (Math.random() * 2 + 2) + 's';
                document.body.appendChild(star);
                
                // 清理星星
                setTimeout(() => {
                    star.remove();
                }, 5000);
            }
        }

        // 页面加载完成后执行
        window.onload = function() {
            createBalloons();
        };

        // 点击页面任意位置生成星星
        document.body.addEventListener('click', createStars);
    </script>
</body>
</html>
